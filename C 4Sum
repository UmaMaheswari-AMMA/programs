#include <stdlib.h>

int compare(const void* a, const void* b) {
    long long diff = *(int*)a - *(int*)b;
    return (diff > 0) - (diff < 0);
}

int** fourSum(int* nums, int numsSize, int target, int* returnSize, int** returnColumnSizes) {
    *returnSize = 0;
    if (numsSize < 4) return NULL;

    // 1. Sort the array
    qsort(nums, numsSize, sizeof(int), compare);

    int capacity = 1000;
    int** res = malloc(capacity * sizeof(int*));
    *returnColumnSizes = malloc(capacity * sizeof(int));

    for (int i = 0; i < numsSize - 3; i++) {
        // Skip duplicate for the first number
        if (i > 0 && nums[i] == nums[i - 1]) continue;
        
        // Optimization: If the smallest 4 numbers exceed target, stop
        if ((long long)nums[i] + nums[i+1] + nums[i+2] + nums[i+3] > target) break;
        // Optimization: If current number + largest 3 numbers < target, skip i
        if ((long long)nums[i] + nums[numsSize-1] + nums[numsSize-2] + nums[numsSize-3] < target) continue;

        for (int j = i + 1; j < numsSize - 2; j++) {
            // Skip duplicate for the second number
            if (j > i + 1 && nums[j] == nums[j - 1]) continue;

            int left = j + 1;
            int right = numsSize - 1;

            while (left < right) {
                long long sum = (long long)nums[i] + nums[j] + nums[left] + nums[right];

                if (sum == target) {
                    res[*returnSize] = malloc(4 * sizeof(int));
                    res[*returnSize][0] = nums[i];
                    res[*returnSize][1] = nums[j];
                    res[*returnSize][2] = nums[left];
                    res[*returnSize][3] = nums[right];
                    (*returnColumnSizes)[*returnSize] = 4;
                    (*returnSize)++;

                    if (*returnSize == capacity) {
                        capacity *= 2;
                        res = realloc(res, capacity * sizeof(int*));
                        *returnColumnSizes = realloc(*returnColumnSizes, capacity * sizeof(int));
                    }

                    while (left < right && nums[left] == nums[left + 1]) left++;
                    while (left < right && nums[right] == nums[right - 1]) right--;
                    left++;
                    right--;
                } else if (sum < target) {
                    left++;
                } else {
                    right--;
                }
            }
        }
    }
    return res;
}
