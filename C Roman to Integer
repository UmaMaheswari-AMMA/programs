#include <string.h>

int getVal(char c) {
    switch (c) {
        case 'I': return 1;
        case 'V': return 5;
        case 'X': return 10;
        case 'L': return 50;
        case 'C': return 100;
        case 'D': return 500;
        case 'M': return 1000;
        default: return 0;
    }
}

int romanToInt(char* s) {
    int total = 0;
    int len = strlen(s);

    for (int i = 0; i < len; i++) {
        int current = getVal(s[i]);
        
        // If there's a next character and its value is greater, subtract current
        if (i + 1 < len) {
            int next = getVal(s[i + 1]);
            if (current < next) {
                total -= current;
            } else {
                total += current;
            }
        } else {
            // Last character is always added
            total += current;
        }
    }

    return total;
}
