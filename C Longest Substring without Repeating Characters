#include <string.h>
#include <math.h>

#define MAX(a, b) ((a) > (b) ? (a) : (b))

int lengthOfLongestSubstring(char* s) {
    int n = strlen(s);
    int maxLength = 0;
    
    // Array to store the last index of each character
    // Initialize all to -1
    int lastSeen[128];
    for (int i = 0; i < 128; i++) {
        lastSeen[i] = -1;
    }

    int left = 0;
    for (int right = 0; right < n; right++) {
        char currentChar = s[right];

        // If the character was seen before AND is inside the current window
        if (lastSeen[currentChar] >= left) {
            // Move left pointer to the right of the previous occurrence
            left = lastSeen[currentChar] + 1;
        }

        // Update the last seen position of the character
        lastSeen[currentChar] = right;

        // Calculate current window size and update maxLength
        maxLength = MAX(maxLength, right - left + 1);
    }

    return maxLength;
}
