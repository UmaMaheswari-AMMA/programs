#include <stdio.h>
#include <stdlib.h>
#include <string.h>

char* convert(char* s, int numRows) {
    int len = strlen(s);
    
    // Edge case: If numRows is 1 or string is shorter than rows, no change needed
    if (numRows <= 1 || numRows >= len) return s;

    // Create an array of strings (rows)
    // We use a flat buffer for the result to keep space complexity O(n)
    char* result = (char*)malloc((len + 1) * sizeof(char));
    int count = 0;
    
    // The cycle length for a full "V" shape is (2 * numRows - 2)
    int cycleLen = 2 * numRows - 2;

    for (int i = 0; i < numRows; i++) {
        for (int j = 0; j + i < len; j += cycleLen) {
            // Add the character going down
            result[count++] = s[j + i];
            
            // Add the character going up (the diagonal)
            // Diagonals don't exist for the first and last rows
            int diagonalIdx = j + cycleLen - i;
            if (i != 0 && i != numRows - 1 && diagonalIdx < len) {
                result[count++] = s[diagonalIdx];
            }
        }
    }
    
    result[count] = '\0';
    return result;
}
