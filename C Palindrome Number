#include <stdbool.h>

bool isPalindrome(int x) {
    // 1. Negative numbers are NOT palindromes.
    // 2. If the last digit is 0, the first digit must be 0 (only possible for x=0).
    if (x < 0 || (x % 10 == 0 && x != 0)) {
        return false;
    }

    int reversedHalf = 0;
    
    // Reverse only half of the number to prevent overflow and save time
    while (x > reversedHalf) {
        reversedHalf = (reversedHalf * 10) + (x % 10);
        x /= 10;
    }

    // If length is even: x == reversedHalf (e.g., 12 | 12)
    // If length is odd: x == reversedHalf / 10 (e.g., 1 | 12)
    return x == reversedHalf || x == reversedHalf / 10;
}
