#include <stdbool.h>

bool isPalindrome(int x) {
    // Special cases:
    // 1. Negative numbers are not palindromes (e.g., -121 != 121-)
    // 2. Numbers ending in 0 (except 0 itself) are not palindromes
    if (x < 0 || (x % 10 == 0 && x != 0)) {
        return false;
    }

    int reversedHalf = 0;
    while (x > reversedHalf) {
        // Build the reversed number digit by digit
        reversedHalf = reversedHalf * 10 + (x % 10);
        x /= 10;
    }

    // For even digits (1221), x will equal reversedHalf (12 == 12)
    // For odd digits (121), we discard the middle digit: x == reversedHalf/10 (1 == 12/10)
    return x == reversedHalf || x == reversedHalf / 10;
}
