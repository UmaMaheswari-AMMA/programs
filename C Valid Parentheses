#include <stdbool.h>
#include <string.h>

bool isValid(char* s) {
    int len = strlen(s);
    // A stack to store opening brackets
    char stack[len];
    int top = -1;

    for (int i = 0; i < len; i++) {
        char c = s[i];

        // 1. If it's an opening bracket, push to stack
        if (c == '(' || c == '[' || c == '{') {
            stack[++top] = c;
        } 
        // 2. If it's a closing bracket, check for a match
        else {
            // If stack is empty, there's no matching opening bracket
            if (top == -1) return false;

            char last = stack[top--];
            if ((c == ')' && last != '(') ||
                (c == ']' && last != '[') ||
                (c == '}' && last != '{')) {
                return false;
            }
        }
    }

    // 3. If stack is empty, all brackets were matched correctly
    return top == -1;
}
